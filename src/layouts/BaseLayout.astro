---
// BaseLayout.astro - Tüm sayfaların ana şablonu
const { title } = Astro.props;
---
<!doctype html>
<html lang="tr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Esse Güzellik</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
    <slot /> <!-- Sayfa içeriği buraya gelecek -->
</body>
</html>

<style>
    :root {
        --gold: #D4AF37;
        --dark: #111111;
        --white: #ffffff;
        --light-gray: #f9f9f9;
        --text-gray: #666666;
    }
    
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }
    
    body {
        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
        background-color: var(--white);
        color: #333;
        line-height: 1.6;
    }
    
    a {
        text-decoration: none;
        color: inherit;
        transition: color 0.3s ease;
    }
    
    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 20px;
    }
    
    h1, h2, h3 {
        color: var(--dark);
        margin-bottom: 1rem;
    }
</style>