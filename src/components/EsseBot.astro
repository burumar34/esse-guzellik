<!-- EsseBot.astro - Müşteri Asistanı -->
<div class="esse-bot-wrapper">
    <button class="bot-toggle" id="botToggle">💬 Esse Bot</button>
    <div class="bot-window" id="botWindow" style="display: none;">
        <div class="bot-header">
            <span>🤖 Esse Güzellik Asistanı</span>
            <button class="close-btn" id="closeBot">×</button>
        </div>
        <div class="bot-messages" id="botMessages">
            <div class="message bot-message">Merhaba! Size nasıl yardımcı olabilirim? 😊</div>
        </div>
        <div class="bot-input-area">
            <input type="text" placeholder="Mesajınızı yazın..." id="botInput" />
            <button id="sendBtn">Gönder</button>
        </div>
    </div>
</div>

<style>
    .esse-bot-wrapper {
        position: fixed;
        bottom: 20px;
        right: 20px;
        z-index: 9999;
    }
    
    .bot-toggle {
        background: var(--gold);
        color: var(--dark);
        border: none;
        padding: 15px 25px;
        border-radius: 50px;
        font-weight: bold;
        cursor: pointer;
        box-shadow: 0 4px 12px rgba(212, 175, 55, 0.4);
        transition: transform 0.3s ease;
    }
    
    .bot-toggle:hover {
        transform: scale(1.05);
    }
    
    .bot-window {
        position: absolute;
        bottom: 70px;
        right: 0;
        width: 350px;
        height: 500px;
        background: white;
        border-radius: 12px;
        box-shadow: 0 8px 24px rgba(0,0,0,0.15);
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }
    
    .bot-header {
        background: var(--dark);
        color: var(--gold);
        padding: 15px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-weight: bold;
    }
    
    .close-btn {
        background: none;
        border: none;
        color: white;
        font-size: 1.5rem;
        cursor: pointer;
    }
    
    .bot-messages {
        flex: 1;
        padding: 15px;
        overflow-y: auto;
        background: var(--light-gray);
    }
    
    .message {
        margin-bottom: 10px;
        padding: 10px 15px;
        border-radius: 12px;
        max-width: 80%;
        font-size: 0.9rem;
    }
    
    .bot-message {
        background: white;
        border: 1px solid #eee;
        align-self: flex-start;
    }
    
    .user-message {
        background: var(--gold);
        color: var(--dark);
        align-self: flex-end;
        margin-left: auto;
    }
    
    .bot-input-area {
        padding: 15px;
        border-top: 1px solid #eee;
        display: flex;
        gap: 10px;
    }
    
    .bot-input-area input {
        flex: 1;
        padding: 10px;
        border: 1px solid #ddd;
        border-radius: 8px;
        outline: none;
    }
    
    .bot-input-area button {
        background: var(--gold);
        border: none;
        padding: 10px 20px;
        border-radius: 8px;
        cursor: pointer;
        font-weight: bold;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const toggle = document.getElementById('botToggle');
        const window = document.getElementById('botWindow');
        const close = document.getElementById('closeBot');
        
        if(toggle && window && close) {
            toggle.addEventListener('click', () => {
                window.style.display = window.style.display === 'none' ? 'flex' : 'none';
            });
            
            close.addEventListener('click', () => {
                window.style.display = 'none';
            });
        }
    });
</script>